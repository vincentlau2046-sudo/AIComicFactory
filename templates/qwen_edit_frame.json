{
  "_comment": "qwen-image-edit 单角色帧生成工作流 (S5) — v2.2 fit+pad resolution alignment",
  "_changelog": {
    "v2.0": "Aligned with official Vantage workflow: removed ReferenceLatent/FluxKontext, euler/simple sampler",
    "v2.1": "Added ImageScale before VAEEncode (caused distortion from 1024×1536→1280×720)",
    "v2.2": "Replaced ImageScale with fit+pad: LoadImage(original)→TextEncode, LoadImage(padded 1280×720)→VAEEncode. No distortion."
  },
  "_architecture": {
    "resolution_chain": "S3 ref(1024×1536) → Python fit+pad(480×720 in 1280×720 white) → VAEEncode → 1280×720 output",
    "conditioning": "TextEncodeQwenImageEditPlus gets original-res image1 (full detail for CLIP)",
    "latent": "VAEEncode gets padded 1280×720 image (controls output resolution, no distortion)"
  },

