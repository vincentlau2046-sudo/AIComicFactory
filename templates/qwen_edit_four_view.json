{
  "_comment": "qwen-image-edit 四视角工作流 (S3b) — v2.1 with ImageScale for resolution alignment",
  "_changelog": {
    "v2.0": "Aligned with official Vantage-Qwen-Image-Edit-2511 workflow: removed ReferenceLatent/FluxKontextMultiReferenceLatentMethod, VAEEncode direct to KSampler, euler/simple sampler, negative shares image1 and vae",
    "v2.1": "Added ImageScale before VAEEncode to enforce output resolution; S3b uses 1024×1536 portrait for character detail"
  },
  "_requirements": [
    "ComfyUI must NOT run with --use-sage-attention (causes black output)",
    "Lightning LoRA: Qwen-Image-Edit-2511-Lightning-4steps-V1.0-bf16.safetensors",
    "Checkpoint: qwen_image_edit_2511_fp8mixed.safetensors (in diffusion_models/)",
    "CLIP: qwen_2.5_vl_7b_fp8_scaled.safetensors (in text_encoders/)",
    "VAE: qwen_image_vae.safetensors (in vae/)"
  ],

  "12": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "qwen_image_edit_2511_fp8mixed.safetensors",
      "weight_dtype": "default"
    }
  },
  "61": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "qwen_2.5_vl_7b_fp8_scaled.safetensors",
      "type": "qwen_image"
    }
  },
  "10": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "qwen_image_vae.safetensors"
    }
  },
  "74": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["12", 0],
      "lora_name": "Qwen-Image-Edit-2511-Lightning-4steps-V1.0-bf16.safetensors",
      "strength_model": 1.0
    }
  },
  "67": {
    "class_type": "ModelSamplingAuraFlow",
    "inputs": {
      "model": ["74", 0],
      "shift": 3.1
    }
  },
  "64": {
    "class_type": "CFGNorm",
    "inputs": {
      "model": ["67", 0],
      "strength": 1
    }
  },
  "41": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "placeholder.png"
    }
  },
  "80": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["41", 0],
      "width": 1024,
      "height": 1536,
      "upscale_method": "lanczos",
      "crop": "disabled"
    }
  },
  "75": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["80", 0],
      "vae": ["10", 0]
    }
  },
  "68": {
    "class_type": "TextEncodeQwenImageEditPlus",
    "inputs": {
      "clip": ["61", 0],
      "prompt": "",
      "vae": ["10", 0],
      "image1": ["41", 0]
    }
  },
  "69": {
    "class_type": "TextEncodeQwenImageEditPlus",
    "inputs": {
      "clip": ["61", 0],
      "prompt": "",
      "vae": ["10", 0],
      "image1": ["41", 0]
    }
  },
  "65": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 4,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["64", 0],
      "positive": ["68", 0],
      "negative": ["69", 0],
      "latent_image": ["75", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["65", 0],
      "vae": ["10", 0]
    }
  },
  "60": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "aicf_fourview",
      "images": ["8", 0]
    }
  }
}
